# Required: server-side Gemini key only (never send from RunAI clients in v1).
GEMINI_API_KEY=

# Model ID passed to google-generativeai (default matches RunAI CLI).
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: if set, clients must send Authorization: Bearer <same value>.
PROXY_BEARER_TOKEN=

HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# Comma-separated origins; leave empty to disable CORS.
# Example: https://app.example.com,http://localhost:3000
CORS_ORIGINS=

# Set true only for local debugging — logs assembled prompts (sensitive).
LOG_PROMPTS=false
